# ===========================================================================
# Переменные окружения для Nuxt.
# Скопируйте этот файл в .env и заполните значениями:
#   cp .env.example .env
#
# Nuxt автоматически подхватывает .env через runtimeConfig (nuxt.config.ts).
# Переменные с префиксом NUXT_PUBLIC_ доступны и на клиенте, и на сервере.
# Переменные без префикса — только на сервере.
# ===========================================================================

# Публичный URL API (доступен на клиенте через useRuntimeConfig().public.apiUrl)
NUXT_PUBLIC_API_URL=http://localhost:8000

# Приватный URL FastAPI (только на сервере, через useRuntimeConfig().fastApiUrl)
FASTAPI_URL=http://localhost:8000
