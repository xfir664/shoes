# EditorConfig для nuxt-nest-test проекта
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,jsx,tsx,vue}]
indent_style = tab
indent_size = 2

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{py,rb,go,rs}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
